<?xml version="1.0" ?>
<robot name="new_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find robot_arm2)/urdf/new_arm/materials.xacro" />
<xacro:include filename="$(find robot_arm2)/urdf/new_arm/new_arm.ros2_control.xacro" />
<xacro:include filename="$(find robot_arm2)/urdf/new_arm/new_arm.gazebo.xacro" />

<!-- Fixed world link to anchor the robot -->
<link name="world"/>
<joint name="world_fixed" type="fixed">
  <origin xyz="0 0 3" rpy="0 0 0"/>
  <parent link="world"/>
  <child link="base_link"/>
</joint>


<link name="base_link">
  <inertial>
    <origin xyz="2.6053033236148976e-09 2.0430511184727322e-05 -0.00030798270803188604" rpy="0 0 0"/>
    <mass value="0.15004727239335192"/>
    <inertia ixx="0.000118" iyy="0.000321" izz="0.000438" ixy="-0.0" iyz="-0.0" ixz="-0.0"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find robot_arm2)/meshes/new_arm/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find robot_arm2)/meshes/new_arm/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

